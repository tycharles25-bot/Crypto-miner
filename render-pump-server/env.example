# Render Pump Server - set these in Render Dashboard → Environment

# Pump detection: 50–150% gain in 10 min (new tokens only)
MIN_PUMP_PERCENT=50
MAX_PUMP_PERCENT=150

# Holders: max 20 (new tokens being pumped)
MIN_HOLDERS=1
MAX_HOLDERS=20

# Required for holder filter
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api_key=YOUR_KEY
