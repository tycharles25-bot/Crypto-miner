# Copy to .env and fill in
PORT=3000

# Solana wallet private key (base58) - for auto-swaps
SOLANA_PRIVATE_KEY=

# RPC: rotates across multiple URLs to multiply rate limit. Add more for higher throughput.
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_RPC_URL_2=https://solana-rpc.publicnode.com
# SOLANA_RPC_URL_3=https://rpc.ankr.com/solana
# SOLANA_RPC_URL_4=https://api.mainnet.solana.com
# SOLANA_RPC_URL_5=https://solana-mainnet.gateway.tatum.io
# WebSocket for real-time swaps (same host as RPC, wss://). Much higher throughput than polling.
# SOLANA_WS_URL=wss://your-node.example.com

# Trading config
SOL_PER_TRADE_LAMPORTS=10000000
SLIPPAGE_BPS=500
# Jupiter: API key required (portal.jup.ag). Higher slippage (500-1000) for Pump.fun tokens.
# JUPITER_API_KEY=

# Pump formulas to run: hundredPerc10min | fiftyPerc20min
PUMP_DEFINITION=hundredPerc10min

# Data source: gecko | dexscreener | birdeye | both | all | chain
# chain = RPC only, no 3rd party APIs (fully independent).
# Chain-only setup: 1) REDIS_URL 2) npm run catalog (builds 892k tokens, saves to Redis) 3) CHAIN_ONLY=true CHAIN_SCANNER_ENABLED=true
# CHAIN_ONLY=true  # or DATA_SOURCE=chain
DATA_SOURCE=both

# GeckoTerminal: trending pages (1-10), new pools, top pools
SOLANA_POOL_PAGES=5

# Delay between API calls (ms) - higher = fewer rate limits, slower scan
# Max rate: 2000 (Gecko ~30 tokens/min). Default: 3500 (~17/min)
POOL_DELAY_MS=2000

# DexScreener: delay between token-pairs calls (ms). 300 req/min limit.
# Max rate: 200 = ~300 tokens/min. Default: 250 = ~240/min
DEXSCREENER_DELAY_MS=200

# Birdeye: 14k+ tokens. Get key at bds.birdeye.so. When set, Birdeye is used with gecko/dexscreener
# DATA_SOURCE: gecko | dexscreener | birdeye | both
# Max rate: BIRDEYE_PAGES=30, BIRDEYE_DELAY_MS=800 (~90/min)
BIRDEYE_API_KEY=
BIRDEYE_PAGES=25
BIRDEYE_DELAY_MS=900

# Page scanner: 1 Birdeye page per minute (50 tokens). Site with most tokens via API.
# DexScreener (43k pairs) is Cloudflare-protected - not scrapeable.
# PAGE_SCANNER_ENABLED=true
# PAGE_SCANNER_INTERVAL_MS=60000

# Chain-only: RPC + logsSubscribe only. No Birdeye, DexScreener, Gecko, PumpApi.
# CHAIN_ONLY=true
# CHAIN_USE_CONTRIBUTE=true  # allow contribute when chain-only (workers may use 3rd party to fetch)
# CHAIN_SCANNER_ENABLED=true  # Event-driven: only fetches bonding curves for mints that had a swap. Works with public RPC.
# CHAIN_SCANNER_BATCH=100
# CHAIN_SCANNER_RATE=150
# CHAIN_SCANNER_INTERVAL_MS=60000

# Token catalog: 1M target. Disabled when CHAIN_ONLY. Aggregates Birdeye, Raydium, Jupiter, etc.
# Run: npm run catalog (standalone) or enable for background build every 6h.
# TOKEN_CATALOG_ENABLED=true
# TOKEN_CATALOG_INTERVAL_HOURS=6

# RPC Indexer: polls RPC for DEX swaps (Jupiter, Raydium, Pump). Free, no API key.
# Public RPC rate-limits heavily - use personal node or paid RPC for chain-only / 892k/min.
# Max rate: POLL_MS=10000, BATCH=25, DELAY=300
RPC_INDEXER_ENABLED=true
RPC_INDEXER_POLL_MS=12000
RPC_INDEXER_BATCH=20
RPC_INDEXER_DELAY_MS=350

# Worker mode: HUB_URL=... runs contribute-only (no trading). Deploy on separate servers.
# HUB_URL=https://your-hub.com
# WORKER_INTERVAL_MS=120000
# WORKER_MAX_POOLS=25

# Distributed mesh (Phase 2): Redis shared store. Workers + hub write/read here.
# Set REDIS_URL to enable. Workers can use REDIS_URL instead of HUB_URL to write directly.
# REDIS_URL=redis://localhost:6379

# Multi-worker on one machine: copy workers.json.example to workers.json, add proxy URLs
# npm run workers  # spawns N workers, each with different proxy = different IP

# VPN workers (docker-compose.workers.yml)
# Free: Windscribe (unlimited connections, 10GB/mo) - windscribe.com/getconfig/wireguard
# Free: ProtonVPN (1 connection) - add FREE_ONLY=on
# VPN_SERVICE_PROVIDER=windscribe
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=your_private_key
# WIREGUARD_ADDRESSES=100.64.x.x/32

# Contribute rate limit: requests per minute per IP. Raise if you have many workers.
# Max: 60 for many workers. Default: 30
# CONTRIBUTE_RATE_LIMIT_PER_IP=30
